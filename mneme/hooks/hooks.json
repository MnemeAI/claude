{
  "description": "Mneme memory hooks: fallback on API failure, reminder on session end",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__mneme__create_memory",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/fallback-memory.sh\"",
            "timeout": 10,
            "statusMessage": "Checking memory save result..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/stop-check.sh\"",
            "timeout": 5,
            "statusMessage": "Remember to save memory-worthy learnings with /mneme:memorize"
          }
        ]
      }
    ]
  }
}
